# === TELEGRAM ===
# Get from @BotFather on Telegram: /newbot → copy the token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get by messaging your bot, then visiting:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat":{"id": YOUR_CHAT_ID }
TELEGRAM_CHAT_ID=your_chat_id_here

# === SUPABASE ===
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# === APP ===
# Set a simple PIN to protect the web dashboard (optional)
DASHBOARD_PIN=

# Timezone — do not change
TIMEZONE=Asia/Kolkata

# === VERCEL CRON SECRET ===
# Generate any random string. Used to secure cron endpoints.
CRON_SECRET=your_random_secret_here
